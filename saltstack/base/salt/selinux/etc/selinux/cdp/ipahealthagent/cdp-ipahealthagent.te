policy_module(cdp-ipahealthagent, 1.0.0)

gen_require(`
    type initrc_exec_t, default_t, cdp_salt_srv_t, unconfined_t;
')

type cdp_ipahealthagent_t;
type cdp_ipahealthagent_exec_t;
type cdp_ipahealthagent_cert_t;

init_daemon_domain(cdp_ipahealthagent_t, cdp_ipahealthagent_exec_t)

allow cdp_ipahealthagent_t cdp_ipahealthagent_cert_t:file { read open getattr write create unlink };

filetrans_pattern(unconfined_t, default_t, cdp_ipahealthagent_exec_t, file, "freeipa_healthagent_getcerts.sh")
filetrans_pattern(cdp_ipahealthagent_exec_t, default_t, cdp_ipahealthagent_cert_t, file, "publicCert.pem")
filetrans_pattern(cdp_ipahealthagent_exec_t, default_t, cdp_ipahealthagent_cert_t, file, "privateKey.pem")
